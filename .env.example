# Hetzner Cloud API Token (erforderlich)
# Erstelle einen Token unter: https://console.hetzner.cloud/ -> Projekt -> Security -> API tokens
HCLOUD_TOKEN=your_api_token_here
# Optional weitere Accounts (Suffix wird zur Account-ID, z.B. "om")
# HCLOUD_TOKEN_OM=your_second_project_token
# HCLOUD_DEFAULT_ACCOUNT=default

# Optional: Standard-Einstellungen
HCLOUD_DEFAULT_LOCATION=fsn1
HCLOUD_DEFAULT_SSH_KEY=

# Docker Monitoring (optional, mehrere Hosts)
# Format: [{"name":"Main","host":"46.225.53.7","user":"root","port":22}]
DOCKER_MONITOR_SERVERS=[]
